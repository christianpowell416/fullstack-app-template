# ===========================================
# Next.js Website Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.

# --- Supabase (public — safe for browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Supabase (secret — server-side only) ---
# Get from: Supabase Dashboard → Settings → API → service_role key
# WARNING: This key bypasses RLS. Never expose it client-side.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Cron Job Authentication ---
# Protects your /api/cron/* endpoints from unauthorized access.
# Vercel automatically sends this as a Bearer token for configured cron jobs.
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# --- Email (Resend) ---
# Get from: resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL="Your App <hello@yourdomain.com>"

# --- Email Webhook Verification ---
# Get from: resend.com → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# --- RevenueCat Webhook ---
# Get from: RevenueCat → Project → Webhooks → Webhook Secret
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret_here

# --- Site URL ---
# Used for generating absolute URLs (unsubscribe links, cron triggers, etc.)
# Falls back to VERCEL_URL if not set.
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com

# --- Admin Alerts ---
# Email address for system alerts (error reports, cost alerts, daily digests)
ADMIN_ALERT_EMAIL=you@yourdomain.com

# --- Gem API (recruiting platform) ---
# Get from: Gem → Team Settings → Integrations → API Keys
# Used to pull outbound message metrics and candidate events.
# WARNING: Server-side only. Never expose client-side.
GEM_API_KEY=your_gem_api_key_here

# --- OpenAI (optional — for admin AI features like email generation) ---
# Only needed if your admin dashboard uses AI features server-side.
OPENAI_ADMIN_API_KEY=sk-your_openai_admin_key_here

# --- Google Cloud / BigQuery (optional — for cost analytics) ---
# Only needed if you export GCP billing to BigQuery for cost reconciliation.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_CREDENTIALS={"type":"service_account","project_id":"..."}
# BIGQUERY_DATASET=billing_export
# BIGQUERY_TABLE=gcp_billing_export_v1_XXXXXX

# --- Cost Alert Threshold (optional) ---
# Daily cost threshold in USD that triggers an alert email.
# DAILY_COST_ALERT_THRESHOLD=25

# --- Unsubscribe Token ---
# Secret for signing unsubscribe links. Falls back to RESEND_API_KEY if not set.
# Generate with: openssl rand -hex 32
# UNSUBSCRIBE_SECRET=your_unsubscribe_secret_here
