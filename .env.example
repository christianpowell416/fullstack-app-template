# ===========================================
# Mobile App Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# These are bundled into the app — only use EXPO_PUBLIC_ for non-secret values.

# --- Supabase ---
# Get these from: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Google OAuth (optional) ---
# Get from: Google Cloud Console → Credentials → OAuth 2.0 Client ID
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# --- RevenueCat (in-app purchases) ---
# Get from: RevenueCat → Project → API Keys → Public API Key
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_your_revenuecat_key_here

# --- Development ---
# A shared secret between your app and Edge Functions to bypass rate limits during dev.
# Generate with: openssl rand -base64 32
EXPO_PUBLIC_DEV_BYPASS_KEY=your_dev_bypass_key_here
