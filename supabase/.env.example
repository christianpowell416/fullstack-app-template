# ===========================================
# Supabase Edge Function Secrets
# ===========================================
# These are set with: supabase secrets set KEY=value
# They are NOT stored in a file — this is just a reference.
#
# Note: SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY
# are automatically injected by Supabase. You do NOT need to set them.

# --- OpenAI ---
# Used by ai-proxy for chat completions, transcription, TTS
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# --- Google Gemini ---
# Used by ai-proxy for image generation & editing, and text generation
# Get from: aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# --- Development Bypass ---
# Shared secret between mobile app and Edge Functions.
# When the app sends this key, rate limits are relaxed for dev/testing.
# Must match EXPO_PUBLIC_DEV_BYPASS_KEY in your mobile .env.local
# Generate with: openssl rand -base64 32
DEV_BYPASS_KEY=your_dev_bypass_key_here

# --- How to set these ---
# supabase secrets set OPENAI_API_KEY=sk-...
# supabase secrets set GEMINI_API_KEY=AI...
# supabase secrets set DEV_BYPASS_KEY=...
#
# To verify they're set:
# supabase secrets list
